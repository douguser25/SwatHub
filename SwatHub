local function MakePlayerList(parent, onSelect)
    local plrList = Instance.new("ScrollingFrame",parent)
    plrList.Size = UDim2.new(1,0,0,160)
    plrList.BackgroundColor3 = Color3.fromRGB(10,10,10)
    plrList.BorderSizePixel = 0
    plrList.ScrollBarThickness = 3
    plrList.ScrollBarImageColor3 = Color3.fromRGB(0,200,100)
    plrList.CanvasSize = UDim2.new(0,0,0,0)
    plrList.AutomaticCanvasSize = Enum.AutomaticSize.Y
    plrList.ZIndex = 13
    Instance.new("UICorner",plrList).CornerRadius = UDim.new(0,8)
    local ll = Instance.new("UIListLayout",plrList)
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.Padding = UDim.new(0,2)
    local lp = Instance.new("UIPadding",plrList)
    lp.PaddingAll = UDim.new(0,4)

    local function Refresh()
        for _,v in pairs(plrList:GetChildren()) do
            if v:IsA("TextButton") then v:Destroy() end
        end
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local pb = Instance.new("TextButton",plrList)
                pb.Size = UDim2.new(1,0,0,34)
                pb.BackgroundColor3 = Color3.fromRGB(18,18,18)
                pb.BorderSizePixel = 0
                pb.Text = "  "..p.Name
                pb.TextColor3 = Color3.fromRGB(200,200,200)
                pb.Font = Enum.Font.Gotham
                pb.TextSize = 13
                pb.TextXAlignment = Enum.TextXAlignment.Left
                pb.ZIndex = 14
                Instance.new("UICorner",pb).CornerRadius = UDim.new(0,6)
                pb.MouseButton1Click:Connect(function()
                    S.SelectedPlayer = p
                    selectedPlayerName = p.Name
                    for _,v2 in pairs(plrList:GetChildren()) do
                        if v2:IsA("TextButton") then
                            v2.BackgroundColor3 = Color3.fromRGB(18,18,18)
                            v2.TextColor3 = Color3.fromRGB(200,200,200)
                        end
                    end
                    pb.BackgroundColor3 = Color3.fromRGB(0,100,50)
                    pb.TextColor3 = Color3.fromRGB(255,255,255)
                    if onSelect then onSelect(p) end
                end)
            end
        end
