local function MakeSlider(lbl,desc,min,max,default,cb)
    local row=Instance.new("Frame")
    row.Size=UDim2.new(1,0,0,65) row.BackgroundColor3=Color3.fromRGB(18,18,18)
    row.BorderSizePixel=0 row.ZIndex=12 row.Parent=ContentArea
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,7)
    local l=Instance.new("TextLabel",row)
    l.Size=UDim2.new(0.7,0,0,22) l.Position=UDim2.new(0,10,0,4) l.BackgroundTransparency=1
    l.Text=lbl l.TextColor3=Color3.fromRGB(220,220,220) l.Font=Enum.Font.Gotham
    l.TextSize=13 l.TextXAlignment=Enum.TextXAlignment.Left l.ZIndex=13
    local vl=Instance.new("TextLabel",row)
    vl.Size=UDim2.new(0.25,0,0,22) vl.Position=UDim2.new(0.73,0,0,4) vl.BackgroundTransparency=1
    vl.Text=tostring(default) vl.TextColor3=Color3.fromRGB(255,255,255)
    vl.Font=Enum.Font.GothamBold vl.TextSize=13 vl.TextXAlignment=Enum.TextXAlignment.Right vl.ZIndex=13
    local sbg=Instance.new("Frame",row)
    sbg.Size=UDim2.new(1,-20,0,8) sbg.Position=UDim2.new(0,10,0,42)
    sbg.BackgroundColor3=Color3.fromRGB(40,40,40) sbg.BorderSizePixel=0 sbg.ZIndex=13
    Instance.new("UICorner",sbg).CornerRadius=UDim.new(1,0)
    local fill=Instance.new("Frame",sbg)
    fill.Size=UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3=Color3.fromRGB(200,200,200) fill.BorderSizePixel=0 fill.ZIndex=14
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    local sliding=false
    sbg.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding then
            local pct=math.clamp((i.Position.X-sbg.AbsolutePosition.X)/sbg.AbsoluteSize.X,0,1)
            local val=math.floor(min+(max-min)*pct)
            fill.Size=UDim2.new(pct,0,1,0) vl.Text=tostring(val)
            if cb then cb(val) end
        end
    end)
end

local function MakeSidebarTab(name,icon,order)
    local btn=Instance.new("TextButton")
    btn.Size=UDim2.new(1,0,0,40) btn.BackgroundColor3=Color3.fromRGB(15,15,15)
    btn.BorderSizePixel=0 btn.Text=icon.."  "..name
    btn.TextColor3=Color3.fromRGB(160,160,160) btn.Font=Enum.Font.Gotham
    btn.TextSize=13 btn.TextXAlignment=Enum.TextXAlignment.Left
    btn.ZIndex=12 btn.LayoutOrder=order btn.Parent=Sidebar
    local p=Instance.new("UIPadding",btn) p.PaddingLeft=UDim.new(0,12)
    tabButtons[name]=btn
    return btn
end

local function SetActiveTab(name)
    for n,b in pairs(tabButtons) do
        if n==name then b.BackgroundColor3=Color3.fromRGB(35,35,35) b.TextColor3=Color3.fromRGB(255,255,255)
        else b.BackgroundColor3=Color3.fromRGB(15,15,15) b.TextColor3=Color3.fromRGB(160,160,160) end
    end
    ClearContent()
end

