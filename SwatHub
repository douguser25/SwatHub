-- LOOPS
UserInputService.JumpRequest:Connect(function()
    if Settings.InfiniteJump and Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
end)

RunService.Stepped:Connect(function()
    if Settings.Noclip and Character then
        for _,p in pairs(Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    end
end)

RunService.Heartbeat:Connect(function()
    if Settings.VoidProtection and HumanoidRootPart then
        if HumanoidRootPart.Position.Y < -80 then HumanoidRootPart.CFrame=CFrame.new(0,10,0) end
    end
    if Settings.AntiFling and HumanoidRootPart then
        if HumanoidRootPart.Velocity.Magnitude > 200 then HumanoidRootPart.Velocity=Vector3.new(0,0,0) end
    end
end)

RunService.Heartbeat:Connect(function(dt)
    rgbHue=(rgbHue+dt*Settings.RGBSpeed*0.05)%1
    local color=Color3.fromHSV(rgbHue,1,1)
    if Settings.RGBCorpo and Character then
        for _,p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then p.Color=color end
        end
    end
end)

