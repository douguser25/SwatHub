    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 12
    btn.LayoutOrder = order
    btn.Parent = Sidebar
    local p = Instance.new("UIPadding", btn)
    p.PaddingLeft = UDim.new(0,12)
    tabButtons[name] = btn
    return btn
end

local function SetActiveTab(name)
    for n, b in pairs(tabButtons) do
        if n == name then b.BackgroundColor3 = Color3.fromRGB(35,35,35) b.TextColor3 = Color3.fromRGB(255,255,255)
        else b.BackgroundColor3 = Color3.fromRGB(15,15,15) b.TextColor3 = Color3.fromRGB(160,160,160) end
    end
    ClearContent()
    activeTab = name
end

