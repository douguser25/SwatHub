-- RGB Loop
RunService.Heartbeat:Connect(function(dt)
    rgbHue = (rgbHue + dt * S.RGBSpeed * 0.04) % 1
    local color = Color3.fromHSV(rgbHue,1,1)

    -- RGB Corpo
    if S.RGBCorpo and Character then
        for _,p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                pcall(function() p.Color = color end)
            end
        end
    end

    -- RGB Cabelo
    if S.RGBCabelo and Character then
        for _,p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") and (p.Name:lower():find("hair") or p.Name:lower():find("cabelo")) then
                pcall(function() p.Color = color end)
            end
        end
    end

    -- RGB Casa
    if S.RGBCasa then
        local house = workspace:FindFirstChild(LocalPlayer.Name.."House",true)
        if house then
            for _,p in pairs(house:GetDescendants()) do
                if p:IsA("BasePart") then
                    pcall(function() p.Color = color end)
                end
            end
        end
    end

    -- RGB Carro
    if S.RGBCarro then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("VehicleSeat") then
                local model = v:FindFirstAncestorOfClass("Model")
                if model then
                    for _,p in pairs(model:GetDescendants()) do
                        if p:IsA("BasePart") then
                            pcall(function() p.Color = color end)
                        end
                    end
                end
            end
        end
    end

    -- RGB Nome/Bio
    if S.RGBNomeBio then
        pcall(function()
            local r = game.ReplicatedStorage:FindFirstChild("SetName",true)
            if r then
                local hex = string.format("%02X%02X%02X",
                    math.floor(color.R*255),
                    math.floor(color.G*255),
                    math.floor(color.B*255))
                r:FireServer("["..hex.."] "..LocalPlayer.Name)
            end
        end)
    end
end)

