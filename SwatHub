-- // LOGICA DE NAVEGAÇÃO
local function LoadTab(tabName)
    Content:ClearAllChildren()
    Instance.new("UIListLayout", Content).Padding = UDim.new(0, 8)
    if MenuData[tabName] then MenuData[tabName]() end
end

local TabButtons = {"Credits", "Jogador", "Jogadores", "Extra", "Avatar", "House", "Car", "Tools", "RGB", "Music All", "Music", "Troll", "Protection"}

for _, name in pairs(TabButtons) do
    local b = Instance.new("TextButton", TabScroll)
    b.Size = UDim2.new(1, -10, 0, 35)
    b.BackgroundTransparency = 1
    b.Text = "  " .. name
    b.TextColor3 = Color3.fromRGB(150, 150, 150)
    b.Font = Enum.Font.Gotham
    b.TextXAlignment = "Left"
    
    b.MouseButton1Click:Connect(function()
        for _, btn in pairs(TabScroll:GetChildren()) do
            if btn:IsA("TextButton") then btn.TextColor3 = Color3.fromRGB(150, 150, 150) end
        end
        b.TextColor3 = Color3.fromRGB(0, 255, 150)
        LoadTab(name)
    end)
end

